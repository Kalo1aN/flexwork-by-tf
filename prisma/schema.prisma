generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  phone        String?
  password     String
  status       CandidateStatus @default(pending)
  activatedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  contracts    Contract[]
  bookings     InterviewBooking[]
}

model Job {
  id            String        @id @default(cuid())
  title         String
  company       String
  description   String
  city          String
  mapUrl        String?
  workDate      DateTime
  timeStart     String
  timeEnd       String
  breakMinutes  Int           @default(0)
  rateEurCents  Int
  rateLvCents   Int
  totalEurCents Int
  totalLvCents  Int
  totalSlots    Int
  filledSlots   Int           @default(0)
  jobType       String
  workLocation  String
  languages     String[]
  isActive      Boolean       @default(true)
  isFeatured    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  applications  Application[]
  contracts     Contract[]
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(pending)
  createdAt DateTime          @default(now())
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract  Contract?

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model Contract {
  id             String         @id @default(cuid())
  applicationId  String         @unique
  userId         String
  jobId          String
  contractNumber String         @unique
  contractHtml   String
  signedAt       DateTime?
  signerIp       String?
  signerEmail    String?
  signerName     String?
  status         ContractStatus @default(pending)
  createdAt      DateTime       @default(now())
  application    Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  job            Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
}

enum ApplicationStatus {
  pending
  confirmed
  cancelled
  completed
}

enum ContractStatus {
  pending
  signed
}

model Consultant {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  color       String   @default("#16a34a")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  slots       InterviewSlot[]
  bookings    InterviewBooking[]
}

model InterviewSlot {
  id           String    @id @default(cuid())
  consultantId String
  consultant   Consultant @relation(fields: [consultantId], references: [id])
  startTime    DateTime
  endTime      DateTime
  isBooked     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  booking      InterviewBooking?
}

model InterviewBooking {
  id            String        @id @default(cuid())
  slotId        String        @unique
  slot          InterviewSlot @relation(fields: [slotId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  consultantId  String
  consultant    Consultant    @relation(fields: [consultantId], references: [id])
  status        BookingStatus @default(pending)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum CandidateStatus {
  pending
  active
  suspended
  inactive
}
