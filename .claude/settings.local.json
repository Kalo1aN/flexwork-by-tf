{
  "permissions": {
    "allow": [
      "PowerShell(npx prisma generate)",
      "PowerShell(npx tsc --noEmit)",
      "PowerShell(npm install *)",
      "PowerShell(npm run *)",
      "PowerShell(git *)",
      "PowerShell(npx prisma migrate dev --name init)",
      "PowerShell(npx prisma validate)",
      "PowerShell(npx prisma migrate status)",
      "PowerShell(npx prisma migrate dev --name add_jobs_applications_contracts)",
      "PowerShell(npx tsc --noEmit; if \\($?\\) { \"typecheck OK\" })",
      "PowerShell(git show --stat HEAD --oneline | Select-Object -First 20; \"=== prisma.config.ts diff ===\"; git diff HEAD~1 HEAD -- prisma.config.ts; \"=== settings.local.json diff ===\"; git diff HEAD~1 HEAD -- .claude/settings.local.json)",
      "PowerShell(npx prisma db seed)",
      "Bash(npx tsc *)",
      "Bash(npx prisma *)",
      "Bash(npm run *)",
      "Bash(echo \"exit code: $?  \\(no output above = clean\\)\")",
      "Bash(rm -f tsc_out.txt)",
      "Read(//tmp/**)"
    ]
  }
}
